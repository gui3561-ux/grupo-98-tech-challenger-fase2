# Ambiente
APP_ENV=development
RANDOM_SEED=42

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ecommerce-recommender

# Treinamento
BATCH_SIZE=256
LEARNING_RATE=0.001
NUM_EPOCHS=50
EMBEDDING_DIM=64
HIDDEN_DIMS=128,64,32
EARLY_STOPPING_PATIENCE=5

# Caminhos
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_FEATURES_PATH=data/features
MODELS_PATH=models
